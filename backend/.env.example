# Exemplo para backend/.env. Troque os valores antes de usar.
# Nunca use URLs https:// do Supabase Dashboard ou do frontend como banco.

SECRET_KEY=troque-esta-chave-em-producao
DEBUG=true

# Banco Postgres do Supabase.
# Se voce conectou o Supabase pela Vercel, a variavel equivalente no deploy costuma ser POSTGRES_URL.
POSTGRES_URL=postgresql://postgres.project-ref:sua-senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# DATABASE_URL=postgresql://postgres.project-ref:sua-senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_CONN_MAX_AGE=0

# Desenvolvimento local.
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Producao na Vercel, quando for publicar.
# DEBUG=false
# ALLOWED_HOSTS=seu-backend.vercel.app
# CORS_ALLOWED_ORIGINS=https://seu-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://seu-backend.vercel.app
